-- ── GET ENEMIES ──────────────────────────────────────
local function GetEnemies()
    local list   = {}
    local folder = workspace:FindFirstChild("Enemys")
    if not folder then return list end
    for _, enemy in ipairs(folder:GetChildren()) do
        if enemy:IsA("Model") then
            local guid = enemy:GetAttribute("EnemyGuid")
            local hrp  = enemy:FindFirstChild("HumanoidRootPart")
            local hum  = enemy:FindFirstChildOfClass("Humanoid")
            if guid and hrp and hum and hum.Health > 0 then
                table.insert(list, {
                    model = enemy,
                    guid  = guid,
                    hrp   = hrp,
                })
            end
        end
    end
    return list
end

-- ── AUTO COLLECT via DropItems event ─────────────────
local collectedGuids = {}

local RE_DropItems = Remotes:WaitForChild("DropItems")
RE_DropItems.OnClientEvent:Connect(function(data)
    if not MassAttack.autoCollect then return end
    if not data or not data.rewards then return end
    task.spawn(function()
        for _, reward in pairs(data.rewards) do
            if type(reward) == "table" and reward.guid then
                local guid = reward.guid
                if not collectedGuids[guid] then
                    collectedGuids[guid] = true
                    pcall(function()
                        RE_Collect:InvokeServer(guid)
                    end)
                    MassAttack.collected = MassAttack.collected + 1
                    task.wait(0.02)
                end
            end
        end
    end)
end)

-- ── AUTO DESTROYER ───────────────────────────────────
local destroyerQueue = {}

pcall(function()
    if RE_DrawHero:IsA("RemoteEvent") then
        RE_DrawHero.OnClientEvent:Connect(function(data)
            if not MassAttack.autoCollect then return end
            if data and data.guid then
                table.insert(destroyerQueue, data)
            end
        end)
    end
end)

-- ── TRACK ENEMY DEATH ────────────────────────────────
local deadGuids     = {}
local RE_EnemyDeath = Remotes:WaitForChild("EnemyDeath")
RE_EnemyDeath.OnClientEvent:Connect(function(data)
    if not data then return end
    local guid = data.enemyGuid or data.guid
    if guid then
        deadGuids[guid] = true
        if MassAttack.running then
            MassAttack.killed = MassAttack.killed + 1
        end
    end
end)

-- ── HELPER ───────────────────────────────────────────
local function IsEnemyDead(e)
    if deadGuids[e.guid] then return true end
    if not e.model or not e.model.Parent then return true end
    local hum = e.model:FindFirstChildOfClass("Humanoid")
    return not hum or hum.Health <= 0
end

-- ── AUTO DESTROYER WORKER ────────────────────────────
local function StartDestroyerWorker()
    task.spawn(function()
        while MassAttack.running do
            if #destroyerQueue > 0 then
                local data = table.remove(destroyerQueue, 1)
                pcall(function()
                    RE_DrawHero:InvokeServer({
                        expireTime   = data.expireTime or (os.time() + 30),
                        quirks       = data.quirks or {0, 0, 0},
                        monsterGuid  = data.monsterGuid or "",
                        monsterId    = data.monsterId or 0,
                        guid         = data.guid,
                        multiplier   = data.multiplier or 1,
                        pos          = data.pos or Vector3.new(0,0,0),
                    })
                end)
                task.wait(0.1)
                pcall(function()
                    RE_Extra:FireServer({
                        isSell = true,
                        guid   = data.guid,
                    })
                end)
            end
            task.wait(0.05)
        end
    end)
end

-- ── MAIN ATTACK LOOP ─────────────────────────────────
local function AttackCurrentMap(onStatus)
    deadGuids      = {}
    collectedGuids = {}
    destroyerQueue = {}

    local waitT = 0
    while waitT < 8 do
        if #GetEnemies() > 0 then break end
        task.wait(0.5)
        waitT = waitT + 0.5
    end

    local enemies = GetEnemies()
    if #enemies == 0 then
        if onStatus then onStatus("⚠ Tidak ada musuh di map ini", false) end
        return
    end

    if onStatus then
        onStatus("⚔ " .. #enemies .. " musuh — mulai serang!", true)
    end

    local timeout = 180
    local elapsed = 0

    while MassAttack.running and elapsed < timeout do
        local alive = {}
        for _, e in ipairs(GetEnemies()) do
            if not IsEnemyDead(e) then
                table.insert(alive, e)
            end
        end

        if #alive == 0 then
            if onStatus then
                onStatus("🔄 Semua mati, cek respawn...", true)
            end
            task.wait(2)

            local respawn = GetEnemies()
            if #respawn == 0 then
                break
            else
                deadGuids      = {}
                collectedGuids = {}
                if onStatus then
                    onStatus("♻ Respawn! " .. #respawn .. " musuh baru", true)
                end
                continue
            end
        end

        for _, e in ipairs(alive) do
            if not MassAttack.running then break end
            local hrp = e.model:FindFirstChild("HumanoidRootPart")
            if hrp then
                pcall(function()
                    RE_Click:InvokeServer({
                        enemyGuid = e.guid,
                        enemyPos  = hrp.Position,
                    })
                end)
                pcall(function()
                    RE_Attack:FireServer({
                        attackEnemyGUID = e.guid,
                    })
                end)
            end
        end

        if onStatus then
            onStatus(
                "⚔ "..#alive.." hidup  ✅ "..MassAttack.killed.." mati"
                .."  💎 "..MassAttack.collected.." collect",
                true
            )
        end

        task.wait(MassAttack.spamDelay)
        elapsed = elapsed + MassAttack.spamDelay
    end
end

-- ── MAP ROTATION ─────────────────────────────────────
local MapRotation = {
    selected  = {},
    delay     = 5,
    mapIndex  = 1,
}

local function StartMassAttack(onStatus, onToggle)
    if MassAttack.running then return end
    MassAttack.running   = true
    MassAttack.killed    = 0
    MassAttack.collected = 0

    StartDestroyerWorker()

    MassAttack.thread = task.spawn(function()
        while MassAttack.running do
            local selectedMaps = MapRotation.selected

            if #selectedMaps > 0 then
                for _, mapIdx in ipairs(selectedMaps) do
                    if not MassAttack.running then break end

                    local mapData = MAPS[mapIdx]
                    if onStatus then
                        onStatus(
                            "🗺 Pindah ke " .. mapData.name .. "...",
                            true
                        )
                    end

                    TeleportToMap(mapData)
                    task.wait(MapRotation.delay)

                    AttackCurrentMap(onStatus)

                    if onStatus then
                        onStatus(
                            "✅ " .. mapData.name .. " selesai!"
                            .."  💎 "..MassAttack.collected.." collect",
                            true
                        )
                    end

                    task.wait(0.5)
                end
            else
                AttackCurrentMap(onStatus)
                if MassAttack.running then
                    if onStatus then
                        onStatus("🔄 Ronde selesai, ulang...", true)
                    end
                    task.wait(1)
                end
            end
        end

        MassAttack.running = false
        if onToggle then onToggle(false) end
    end)
end

local function StopMassAttack()
    MassAttack.running = false
    if MassAttack.thread then
        task.cancel(MassAttack.thread)
        MassAttack.thread = nil
    end
end

local function StopMapRotation()
    StopMassAttack()
end

