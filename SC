local guiVisible = false

local function ShowGUI()
    guiVisible = true
    Win.Visible = true
    Win.Size    = UDim2.new(0, GUI_W * 0.85, 0, GUI_H * 0.85)
    Win.Position = UDim2.new(0.5, -(GUI_W * 0.85)/2, 0.5, -(GUI_H * 0.85)/2)
    TweenService:Create(Win, TweenInfo.new(0.22, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
        Size     = UDim2.new(0, GUI_W, 0, GUI_H),
        Position = UDim2.new(0.5, -GUI_W/2, 0.5, -GUI_H/2),
    }):Play()
    fbDot.BackgroundColor3 = Color3.fromRGB(50, 230, 100)
    TweenService:Create(FloatBtn, TweenInfo.new(0.15), {
        BackgroundColor3 = Color3.fromRGB(160, 20, 20)
    }):Play()
end

local function HideGUI()
    guiVisible = false
    TweenService:Create(Win, TweenInfo.new(0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
        Size     = UDim2.new(0, GUI_W * 0.85, 0, GUI_H * 0.85),
        Position = UDim2.new(0.5, -(GUI_W * 0.85)/2, 0.5, -(GUI_H * 0.85)/2),
    }):Play()
    task.delay(0.18, function() Win.Visible = false end)
    fbDot.BackgroundColor3 = Color3.fromRGB(255, 80, 80)
    TweenService:Create(FloatBtn, TweenInfo.new(0.15), {
        BackgroundColor3 = Color3.fromRGB(200, 30, 30)
    }):Play()
end

FloatBtn.MouseButton1Click:Connect(function()
