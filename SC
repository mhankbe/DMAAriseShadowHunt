local Players          = game:GetService("Players")
local TweenService     = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")
local LocalPlayer      = Players.LocalPlayer

-- =====================================================
-- SCREEN SIZE — tunggu sampai valid
-- =====================================================
local PlayerGui = LocalPlayer:WaitForChild("PlayerGui")

local SW, SH
local waited = 0
repeat
    task.wait(0.05)
    waited = waited + 0.05
    SW = PlayerGui.AbsoluteSize.X
    SH = PlayerGui.AbsoluteSize.Y
until (SW > 0 and SH > 0) or waited > 3

if SW == 0 or SH == 0 then
    local vp = workspace.CurrentCamera.ViewportSize
    SW, SH = vp.X, vp.Y
end

-- GUI = 50% lebar layar, rasio 560:630
local GUI_W = math.floor(SW * 0.50)
local GUI_H = math.floor(GUI_W * (630 / 560))

-- Jika tinggi melebihi 85% layar, scale dari tinggi
if GUI_H > SH * 0.85 then
    GUI_H = math.floor(SH * 0.85)
    GUI_W = math.floor(GUI_H * (560 / 630))
end

-- Scale factor (1.0 = desain asli 560px)
local S = GUI_W / 560
local function sc(v) return math.round(v * S) end
local function fs(v) return math.max(6, sc(v)) end

print("[ ASH Hub ] Screen: "..SW.."x"..SH)
print("[ ASH Hub ] GUI: "..GUI_W.."x"..GUI_H.." | Scale: "..math.round(S*100).."%")

