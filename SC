local NavBtnRefs = {}
local ActiveTag  = "main"

local function SwitchTab(tag)
    ActiveTag = tag
    for _, p in pairs(Panels) do p.Visible = false end
    if Panels[tag] then Panels[tag].Visible = true end
    for _, ref in pairs(NavBtnRefs) do
        local on = (ref.tag == tag)
        TweenService:Create(ref.bg, TweenInfo.new(0.18), {
            BackgroundColor3 = on and Color3.fromRGB(160, 20, 20) or Color3.fromRGB(12, 5, 5)
        }):Play()
        ref.accent.BackgroundTransparency = on and 0 or 1
        ref.iconLbl.TextColor3  = on and Color3.fromRGB(255, 200, 200) or Color3.fromRGB(130, 70, 70)
        ref.labelLbl.TextColor3 = on and Color3.fromRGB(255, 255, 255) or Color3.fromRGB(130, 70, 70)
        if on then
            TweenService:Create(ref.bg, TweenInfo.new(0.08), { Size = UDim2.new(1, -sc(10), 0, sc(54)) }):Play()
        else
            TweenService:Create(ref.bg, TweenInfo.new(0.08), { Size = UDim2.new(1, -sc(14), 0, sc(52)) }):Play()
        end
    end
end

