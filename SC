local NavBtnRefs = {}

local function SwitchTab(tag)
    for _, p in pairs(Panels) do p.Visible = false end
    if Panels[tag] then Panels[tag].Visible = true end

    for _, ref in pairs(NavBtnRefs) do
        local on = (ref.tag == tag)
        TweenService:Create(ref.bg, TweenInfo.new(0.16), {
            BackgroundColor3 = on and Color3.fromRGB(72, 24, 165) or Color3.fromRGB(10, 6, 24)
        }):Play()
        ref.ibg.BackgroundColor3 = on and Color3.fromRGB(105, 42, 228) or Color3.fromRGB(20, 10, 44)
        ref.lbl.TextColor3       = on and Color3.fromRGB(255, 255, 255) or Color3.fromRGB(110, 84, 158)
        ref.stroke.Transparency  = on and 0.4 or 1
    end
end

