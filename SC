-- RESPONSIVE SCALING SYSTEM
-- =====================================================
local PlayerGui    = LocalPlayer:WaitForChild("PlayerGui")
local screenSize   = PlayerGui.AbsoluteSize
local screenWidth  = screenSize.X
local screenHeight = screenSize.Y

local isSmartphone = screenWidth < 800
local isTablet     = screenWidth >= 800 and screenWidth < 1200
local isDesktop    = screenWidth >= 1200

-- ── SCALE CALCULATION ────────────────────────────────
local function calculateScale()
    if isSmartphone then
        -- 60% layar smartphone
        local scaleW = (screenWidth  * 0.60) / 560
        local scaleH = (screenHeight * 0.75) / 630
        return math.min(scaleW, scaleH)
    elseif isTablet then
        return math.min(screenWidth / 560, screenHeight / 630) * 0.78
    else
        return math.min(screenWidth / 1920, screenHeight / 1080)
    end
end

local SCALE = math.clamp(calculateScale(), 0.42, 1.3)

-- ── SIZES ─────────────────────────────────────────────
local BASE_WINDOW_W     = 560
local BASE_WINDOW_H     = 630
local BASE_SIDEBAR_W    = 150
local BASE_TITLEBAR_H   = 52

local WINDOW_WIDTH      = math.floor(BASE_WINDOW_W   * SCALE)
local WINDOW_HEIGHT     = math.floor(BASE_WINDOW_H   * SCALE)
local SIDEBAR_WIDTH     = math.floor(BASE_SIDEBAR_W  * SCALE)
local TITLE_BAR_HEIGHT  = math.floor(BASE_TITLEBAR_H * SCALE)

local function scaleFontSize(base)
    return math.max(6, math.floor(base * SCALE))
end

