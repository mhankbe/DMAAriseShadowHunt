-- =====================================================
-- FLOATING TOGGLE BUTTON (SELALU TAMPIL)
-- Hanya muncul di Smartphone & Tablet
-- =====================================================
local guiVisible = true  -- status GUI: tampil atau tidak

if isSmartphone or isTablet then
    local floatSize = isSmartphone and 48 or 56

    local FloatBtn = Instance.new("TextButton", ScreenGui)
    FloatBtn.Name             = "FloatToggle"
    FloatBtn.Size             = UDim2.new(0, floatSize, 0, floatSize)
    -- Posisi pojok kiri bawah, sedikit naik dari tepi
    FloatBtn.Position         = UDim2.new(0, 14, 1, -(floatSize + 80))
    FloatBtn.BackgroundColor3 = Color3.fromRGB(85, 28, 185)
    FloatBtn.BorderSizePixel  = 0
    FloatBtn.Text             = "⚔"
    FloatBtn.TextSize         = isSmartphone and 22 or 26
    FloatBtn.Font             = Enum.Font.GothamBold
    FloatBtn.TextColor3       = Color3.fromRGB(255, 215, 55)
    FloatBtn.AutoButtonColor  = false
    FloatBtn.ZIndex           = 20
    Instance.new("UICorner", FloatBtn).CornerRadius = UDim.new(1, 0)

    -- Gradient & stroke pada floating button
    local fbGrad = Instance.new("UIGradient", FloatBtn)
    fbGrad.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0, Color3.fromRGB(130, 48, 255)),
        ColorSequenceKeypoint.new(1, Color3.fromRGB(68,  14, 165)),
    })
    fbGrad.Rotation = 135

    local fbStroke = Instance.new("UIStroke", FloatBtn)
    fbStroke.Color       = Color3.fromRGB(165, 85, 255)
    fbStroke.Thickness   = 2
    fbStroke.Transparency= 0.2

    -- Dot indikator status (hijau = running, abu = standby)
    local dotSz = 10
    local StatusDot = Instance.new("Frame", FloatBtn)
    StatusDot.Name             = "StatusDot"
    StatusDot.Size             = UDim2.new(0, dotSz, 0, dotSz)
    StatusDot.Position         = UDim2.new(1, -dotSz, 0, 0)
    StatusDot.BackgroundColor3 = Color3.fromRGB(80, 80, 80)
    StatusDot.BorderSizePixel  = 0
    StatusDot.ZIndex           = 21
    Instance.new("UICorner", StatusDot).CornerRadius = UDim.new(1, 0)

    -- ── DRAG FLOATING BUTTON ──────────────────────────
    do
        local fbDrag, fbStart, fbStartPos = false, nil, nil
        local movedEnough = false

        FloatBtn.InputBegan:Connect(function(i)
            if i.UserInputType == Enum.UserInputType.Touch
            or i.UserInputType == Enum.UserInputType.MouseButton1 then
                fbDrag      = true
                movedEnough = false
                fbStart     = i.Position
                fbStartPos  = FloatBtn.Position
            end
        end)

        UserInputService.InputChanged:Connect(function(i)
            if fbDrag and (i.UserInputType == Enum.UserInputType.Touch
                        or i.UserInputType == Enum.UserInputType.MouseMovement) then
                local delta = i.Position - fbStart
                if math.abs(delta.X) > 5 or math.abs(delta.Y) > 5 then
                    movedEnough = true
                end
                FloatBtn.Position = UDim2.new(
                    fbStartPos.X.Scale, fbStartPos.X.Offset + delta.X,
                    fbStartPos.Y.Scale, fbStartPos.Y.Offset + delta.Y
                )
            end
        end)

        UserInputService.InputEnded:Connect(function(i)
            if i.UserInputType == Enum.UserInputType.Touch
            or i.UserInputType == Enum.UserInputType.MouseButton1 then
                fbDrag = false
            end
        end)

        -- Tap: hanya toggle jika tidak di-drag
        FloatBtn.MouseButton1Click:Connect(function()
            if movedEnough then return end  -- abaikan jika sedang drag

            guiVisible = not guiVisible

            -- Animasi pulse saat tap
            TweenService:Create(FloatBtn, TweenInfo.new(0.08), {
                Size = UDim2.new(0, floatSize - 6, 0, floatSize - 6)
            }):Play()
            task.wait(0.08)
            TweenService:Create(FloatBtn, TweenInfo.new(0.12), {
                Size = UDim2.new(0, floatSize, 0, floatSize)
            }):Play()

            -- Show / Hide main GUI dengan tween
            if guiVisible then
                Win.Visible = true
                TweenService:Create(Win, TweenInfo.new(0.22, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
                    Size = UDim2.new(0, WINDOW_WIDTH, 0, WINDOW_HEIGHT)
                }):Play()
                FloatBtn.Text = "⚔"
                fbGrad.Color  = ColorSequence.new({
                    ColorSequenceKeypoint.new(0, Color3.fromRGB(130, 48, 255)),
                    ColorSequenceKeypoint.new(1, Color3.fromRGB(68,  14, 165)),
                })
            else
                TweenService:Create(Win, TweenInfo.new(0.18, Enum.EasingStyle.Quart, Enum.EasingDirection.In), {
                    Size = UDim2.new(0, WINDOW_WIDTH, 0, 0)
                }):Play()
                task.delay(0.18, function() Win.Visible = false end)
                FloatBtn.Text = "▶"
                fbGrad.Color  = ColorSequence.new({
                    ColorSequenceKeypoint.new(0, Color3.fromRGB(68, 22, 140)),
                    ColorSequenceKeypoint.new(1, Color3.fromRGB(36,  8,  80)),
                })
            end
        end)
    end

    -- Update status dot dari MassAttack
    task.spawn(function()
        while ScreenGui.Parent do
            local isRunning = MassAttack.running
            TweenService:Create(StatusDot, TweenInfo.new(0.3), {
                BackgroundColor3 = isRunning
                    and Color3.fromRGB(52, 248, 95)
                    or  Color3.fromRGB(80, 80, 80)
            }):Play()
            task.wait(1.5)
        end
    end)
end

